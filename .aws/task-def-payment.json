{
  "family": "payment-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::190865905880:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "payment",
      "image": "PLACEHOLDER",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "MERCADOPAGO_ACCESS_TOKEN", "value": "MP_TOKEN_PLACEHOLDER" },
        { "name": "MERCADOPAGO_PUBLIC_KEY",   "value": "MP_PUBLIC_KEY_PLACEHOLDER" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/payment-task",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
