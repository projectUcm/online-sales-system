{
  "family": "notification-service",
  "networkMode": "bridge",
  "requiresCompatibilities": ["EC2"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "notification",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/notification-service:latest",
      "portMappings": [
        {
          "containerPort": 8002,
          "hostPort": 8002,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "AWS_REGION", "value": "us-east-1"},
        {"name": "SES_SENDER_EMAIL", "value": "noreply@nexstore.com"},
        {"name": "AWS_ACCESS_KEY_ID", "value": ""},
        {"name": "AWS_SECRET_ACCESS_KEY", "value": ""},
        {"name": "TWILIO_ACCOUNT_SID", "value": ""},
        {"name": "TWILIO_AUTH_TOKEN", "value": ""},
        {"name": "TWILIO_FROM_NUMBER", "value": ""},
        {"name": "SNS_TOPIC_ARN", "value": ""}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/notification-service",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "essential": true
    }
  ]
}
