{
  "family": "backend-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "PLACEHOLDER",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "DATABASE_URL",             "value": "" },
        { "name": "SECRET_KEY",               "value": "supersecretkey123" },
        { "name": "PAYMENT_SERVICE_URL",      "value": "http://online-sales-alb-1964549465.us-east-1.elb.amazonaws.com/payment/pay" },
        { "name": "NOTIFICATION_SERVICE_URL", "value": "" },
        { "name": "AWS_REGION",               "value": "us-east-1" },
        { "name": "AWS_ACCESS_KEY_ID",        "value": "" },
        { "name": "AWS_SECRET_ACCESS_KEY",    "value": "" },
        { "name": "SMTP_HOST",               "value": "smtp.gmail.com" },
        { "name": "SMTP_PORT",               "value": "587" },
        { "name": "SMTP_USER",               "value": "" },
        { "name": "SMTP_PASSWORD",           "value": "" },
        { "name": "SMTP_FROM",              "value": "" },
        { "name": "S3_BUCKET_NAME",           "value": "" },
        { "name": "TWILIO_ACCOUNT_SID",       "value": "" },
        { "name": "TWILIO_AUTH_TOKEN",        "value": "" },
        { "name": "TWILIO_FROM_NUMBER",       "value": "" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/backend-task",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
