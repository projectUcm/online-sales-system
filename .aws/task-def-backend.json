{
  "family": "backend-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::190865905880:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "PLACEHOLDER",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PAYMENT_SERVICE_URL",
          "value": "http://online-sales-alb-667999176.us-east-1.elb.amazonaws.com/payment/pay"
        },
        {
          "name": "DATABASE_URL",
          "value": "postgresql://postgres:Postgres123*@online-sales-db.cwliwem4av1j.us-east-1.rds.amazonaws.com:5432/postgres"
        },
        {
          "name": "SECRET_KEY",
          "value": "supersecretkey123"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/backend-task",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}